# ============================================================
# Labflow .env.example
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================

# --- Convex (Database) ---
# Populated automatically by `npx convex dev` on first run.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# --- Admin auth ---
# The password for /admin/login. Pick something strong (>= 16 chars).
ADMIN_PASSWORD=

# HMAC secret used to sign the admin session cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# Salt for hashing visitor IPs at write time (we never store raw IPs).
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
IP_HASH_SALT=

# Where waitlist notification emails go.
ADMIN_NOTIFY_EMAIL=edonderguti@gmail.com

# --- SMTP for outbound email (AWS SES) ---
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# --- Optional ---
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
